        }
      }
    },
    "Что сегодня показалось случайным, но почему-то задержалось внутри?": {
      "comment": "Prompt for a journal entry of type .sign.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "What felt accidental today, but somehow stayed inside?"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Что сегодня показалось случайным, но почему-то задержалось внутри?"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Was wirkte heute zufällig, ist aber aus irgendeinem Grund in dir geblieben?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Qu’est-ce qui a semblé accidentel aujourd’hui, mais est resté en toi pour une raison quelconque ?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Qué pareció casual hoy, pero por algún motivo se quedó dentro?"
          }
        }
      }
    },
    "Что ты сегодня заметил?": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "What did you notice today?"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Что ты сегодня заметил?"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Was hast du heute bemerkt?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Qu’as-tu remarqué aujourd’hui ?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Qué notaste hoy?"
          }
        }
      }
    },
    "Чувство": {
      "localizations": {

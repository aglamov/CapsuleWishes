    "Сегодня можно начать с малого: что сделало день хотя бы на 1% легче?" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Heute kannst du klein beginnen: Was hat den Tag wenigstens 1 % leichter gemacht?"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Today can start small: what made the day at least 1% lighter?"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hoy puedes empezar por algo pequeño: ¿qué hizo el día al menos un 1 % más ligero?"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",

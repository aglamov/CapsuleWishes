        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La capsule a laissé des signes sur le chemin"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La cápsula dejó señales en el camino"
          }
        }
      }
    },
    "Капсула открылась. Посмотри, сбылось ли то, что ты загадал.": {
      "localizations": {

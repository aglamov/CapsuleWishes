    },
    "Начни с одного наблюдения: что сегодня осталось с тобой дольше обычного?" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Beginne mit einer Beobachtung: Was ist heute länger bei dir geblieben als sonst?"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Start with one observation: what stayed with you longer than usual today?"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Empieza con una observación: ¿qué se quedó contigo hoy más tiempo de lo habitual?"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",

    "Запечатывай желания до выбранного дня, собирай знаки на пути и возвращайся к ним уже другим взглядом." : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Versiegle Wünsche bis zum gewählten Tag, sammle Zeichen auf dem Weg und kehre mit einem anderen Blick zu ihnen zurück."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seal wishes until the day you choose, gather signs along the way, and return to them with a different gaze."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sella deseos hasta el día que elijas, reúne señales en el camino y vuelve a ellos con otra mirada."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Scelle les souhaits jusqu’au jour choisi, recueille les signes en chemin et reviens-y avec un autre regard."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Запечатывай желания до выбранного дня, собирай знаки на пути и возвращайся к ним уже другим взглядом."
          }
        }
      }
    },

    "Что запомнилось из сна, образа или полусна?": {
      "comment": "Prompt for a journal entry of type \"dream\".",
      "isCommentAutoGenerated": true,
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "What stayed with you from a dream, image, or half-sleep?"
          }
        },

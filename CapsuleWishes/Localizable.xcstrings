    "Вернись к капсуле в выбранный день и честно посмотри, как желание изменилось.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Come back to the capsule on the chosen day and honestly notice how the wish has changed."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вернись к капсуле в выбранный день и честно посмотри, как желание изменилось."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Kehre am gewählten Tag zur Kapsel zurück und schau ehrlich, wie sich der Wunsch verändert hat."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Reviens à la capsule le jour choisi et observe honnêtement comment le souhait a changé."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Vuelve a la cápsula el día elegido y mira con honestidad cómo ha cambiado el deseo."
          }
        }
      }
    },

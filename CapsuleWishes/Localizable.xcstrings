    "Капсула открылась. Посмотри, сбылось ли то, что ты загадал." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Kapsel hat sich geöffnet. Schau, ob dein Wunsch wahr geworden ist."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The capsule has opened. See whether the wish you made came true."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La cápsula se abrió. Mira si se cumplió lo que pediste."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La capsule s’est ouverte. Regarde si le souhait que tu as formulé s’est réalisé."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Капсула открылась. Посмотри, сбылось ли то, что ты загадал."

        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "It seems your future self has something to say."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Parece que tu yo futuro quiere decirte algo."

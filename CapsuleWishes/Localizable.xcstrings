    "Сохрани желание, отмечай знаки на пути и вернись к нему в день, который выберешь сам." : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bewahre den Wunsch, achte auf Zeichen unterwegs und kehre an dem Tag zurück, den du selbst wählst."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Save the wish, notice signs along the way, and return to it on the day you choose."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Guarda el deseo, observa las señales del camino y vuelve a él el día que elijas."

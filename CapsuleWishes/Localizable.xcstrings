    "Запечатай намерение, замечай странности и маленькие радости, а потом открой капсулу в нужный день." : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Versiegle eine Absicht, achte auf seltsame Kleinigkeiten und kleine Freuden, und öffne die Kapsel am richtigen Tag."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seal an intention, notice odd little joys, then open the capsule on the right day."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sella una intención, observa rarezas y pequeñas alegrías, y abre la cápsula el día indicado."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Scelle une intention, remarque les étrangetés et les petites joies, puis ouvre la capsule le bon jour."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Запечатай желание, замечай странности, мысли и сны, делай маленькие шаги к мечте, и открой капсулу в нужный день."
          }
        }
      }
    },

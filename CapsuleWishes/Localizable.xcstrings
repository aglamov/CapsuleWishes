    "Сегодня можно начать с малого: что сделало день хотя бы на 1% легче?": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Today can start small: what made the day at least 1% lighter?"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сегодня можно начать с малого: что сделало день хотя бы на 1% легче?"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Heute kannst du klein beginnen: Was hat den Tag wenigstens 1 % leichter gemacht?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aujourd’hui, tu peux commencer petit : qu’est-ce qui a rendu la journée au moins 1 % plus légère ?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Hoy puedes empezar por algo pequeño: ¿qué hizo el día al menos un 1 % más ligero?"
          }
        }
      }
    },

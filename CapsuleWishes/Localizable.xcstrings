    "Сейчас: %@. Будет мягко подстраиваться по первому утреннему открытию приложения." : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jetzt: %@. Wird sich sanft nach dem ersten morgendlichen Öffnen der App ausrichten."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Now: %@. It will gently adjust based on your first morning app opening."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ahora: %@. Se ajustará suavemente según la primera apertura matutina de la app."
